NODE_ENV=development
HOST=0.0.0.0
PORT=8080
DB_PATH=./data/trader.db
MARKET_MODE=mock
SYMBOLS=BTCUSDT,ETHUSDT
TIMEFRAMES=1m,5m,1h
CACHE_LIMIT=2000
STREAM_HISTORY_LIMIT=400
MAX_RISK_PER_TRADE_PCT=1
MAX_DAILY_LOSS_USD=250
MAX_DRAWDOWN_PCT=10
MAX_ORDERS_PER_MINUTE=8
COOLDOWN_LOSS_STREAK=3
FEE_BPS=4
SLIPPAGE_BPS=2
INITIAL_EQUITY_USD=10000
PAPER_ONLY=true
# Relaxed WF thresholds: negative Sharpe is acceptable for RL in early training.
# WF is used to reject catastrophic models, NOT to require profitability yet.
# -99 effectively disables WF sharpe gate — simple promotion (winRate/netPnl) handles quality.
MIN_WF_SHARPE=-99
MIN_WF_PROFIT_FACTOR=0.01
MAX_WF_DRAWDOWN=0.99
MIN_PAPER_PROFIT_FACTOR=0.01
MIN_PAPER_SHARPE=-99
# 1 trade min: mock mode has no real paper trades so lower this drastically.
MIN_PAPER_TRADES=1
ML_SIMPLE_PROMOTION_ENABLED=true
# KEY FIX: allow RL models through the simple winRate/netPnl gate.
# Without this RL was blocked from promotion because OOS gates require paper
# trades that don't exist at training time.
ML_SIMPLE_PROMOTION_ALLOW_RL=true
ML_SIMPLE_PROMOTION_MIN_WIN_RATE=0.5
ML_SIMPLE_PROMOTION_MIN_NET_PNL=0
ML_HOLDOUT_RATIO=0.20
ML_PURGE_BARS=6
ML_RETRAIN_CANDLES_LIMIT=30000
ML_RETRAIN_FILLS_LIMIT=20000
ML_SUPERVISED_WF_FOLDS=4
ML_RL_WF_FOLDS=4
ML_PRETRAIN_MONTHS=6
# Mock mode: disable pretrain (not enough history bars)
ML_PRETRAIN_MIN_CANDLES=200
ML_PRETRAIN_WF_FOLDS=4
# Unseen gate disabled: requires large historical dataset not present in mock mode.
# Re-enable when live candle history >= 30d.
ML_UNSEEN_GATE_ENABLED=false
ML_UNSEEN_BARS=43200
ML_UNSEEN_MIN_PROFIT_FACTOR=1.0
ML_UNSEEN_MIN_SHARPE=0.02
ML_UNSEEN_MIN_TRADES=8
ML_MIN_RETRAIN_INTERVAL_MINUTES=0
RETRAIN_INTERVAL_HOURS=24
MODEL_REGISTRY_PATH=./data/model-registry.json
RL_ENABLED=true
# Increased episodes: agent needs 400 to explore enough before LR decays.
RL_EPISODES=400
RL_LEARNING_RATE=0.04
RL_GAMMA=0.97
# Higher epsilon for better initial exploration.
RL_EPSILON_START=0.5
RL_EPSILON_END=0.05
RL_LATENCY_BARS=0
# Reduced turnover penalty: was killing trade signal.
RL_TURNOVER_PENALTY_BPS=0.1
# Reduced drawdown penalty: was dominating reward.
RL_DRAWDOWN_PENALTY=0.02
# Reduced cost weight 0.5→0.08: costs were swamping PnL signal.
RL_REWARD_COST_WEIGHT=0.08
# Reduced hold penalty 10x: was forcing hold-only policy.
RL_REWARD_HOLD_PENALTY=0.000012
RL_REWARD_ACTION_BONUS=0.000015
RL_MIN_EPISODES=120
# Wider patience: 35 was too tight for reward variance.
RL_EARLY_STOP_PATIENCE=60
RL_EARLY_STOP_MIN_DELTA=0.0002
RL_MIN_RETRAIN_INTERVAL_MINUTES=0
RL_MAX_CONSECUTIVE_NON_PROMOTED=999
RL_COOLDOWN_TRADES_AFTER_STOP=0
# CRITICAL: disable pacing so every call to /ml/retrain does a full RL training
RL_DISABLE_PACING=true
RL_SHADOW_ENABLED=true
RL_REGIME_BALANCED=true
RL_REGIME_LOOKBACK_BARS=96
RL_REGIME_EPISODE_BARS=320
RL_REGIME_STRIDE_BARS=6
RL_PRETRAIN_EPISODES=300
RL_PRETRAIN_MIN_EPISODES=150
RL_HARD_NEG_REPLAY_ENABLED=true
RL_HARD_NEG_REPLAY_EPISODES=80
RL_HARD_NEG_REPLAY_MIN_EPISODES=30
RL_HARD_NEG_REPLAY_MAX_WINDOWS=40
RL_HARD_NEG_REPLAY_WINDOW_BARS=360
RL_SHADOW_GUARD_ENABLED=true
RL_SHADOW_GUARD_GRACE_MINUTES=90
RL_SHADOW_GUARD_MIN_TRADES=16
RL_SHADOW_GUARD_MIN_PF=0.95
RL_SHADOW_GUARD_MAX_DD_PCT=6
RL_SHADOW_GUARD_MIN_NET_PNL_USD=-40
ROLLOUT_MODE=paper
TINY_LIVE_MAX_NOTIONAL_USD=100
ENABLE_LIVE_ORDERS=false
